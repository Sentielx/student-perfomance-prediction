# Public site URL used in sitemap/robots (Render URL or custom domain)
SITE_URL=https://your-app.onrender.com

# Gmail OTP configuration (default)
OTP_PROVIDER=gmail
GMAIL_OTP_SENDER=your_sender@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Local demo fallback (no real email sent)
# OTP_PROVIDER=console

# Resend API provider (works on Render free plan)
# OTP_PROVIDER=resend
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=Your Name <onboarding@resend.dev>
