# Public site URL used in sitemap/robots (Render URL or custom domain)
SITE_URL=https://your-app.onrender.com

# Gmail API OTP configuration (recommended on Render free)
OTP_PROVIDER=gmail_api
GMAIL_API_CLIENT_ID=your_google_oauth_client_id
GMAIL_API_CLIENT_SECRET=your_google_oauth_client_secret
GMAIL_API_REFRESH_TOKEN=your_google_oauth_refresh_token
GMAIL_API_SENDER=your_sender@gmail.com

# Legacy Gmail SMTP fallback (not recommended on Render free)
# OTP_PROVIDER=gmail
# GMAIL_OTP_SENDER=your_sender@gmail.com
# GMAIL_APP_PASSWORD=your_16_char_app_password

# Local demo fallback (no real email sent)
# OTP_PROVIDER=console
